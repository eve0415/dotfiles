{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "MAX_THINKING_TOKENS": "63999",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "DISABLE_EXTRA_USAGE_COMMAND": "1"
  },
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Bash(gh status *)",
      "Bash(gh auth status *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh repo clone *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh release download *)",
      "Bash(gh search *)",
      "Bash(gh gist list *)",
      "Bash(gh gist view *)",
      "Bash(gh label list *)",
      "Bash(gh secret list *)",
      "Bash(gh variable list *)",
      "Bash(gh ruleset list *)",
      "Bash(gh ruleset view *)",
      "Bash(gh cache list *)",
      "Bash(gh org list *)",
      "Bash(gh project list *)",
      "Bash(gh project view *)",
      "Bash(gh project item-list *)",
      "Bash(gh project field-list *)",
      "Bash(gh config get *)",
      "Bash(gh config list *)",
      "Bash(gh alias list *)",
      "Bash(gh extension list *)",
      "Bash(gh extension search *)",
      "Bash(gh search code *)",
      "Bash(gh search issues *)",
      "Bash(gh search prs *)"
    ],
    "defaultMode": "plan"
  },
  "model": "claude-opus-4-6[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/precompact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-code.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "advisorModel": "claude-opus-4-7[1m]",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "plansDirectory": "./.claude/plans",
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": "./.claude/memory",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "useAutoModeDuringPlan": true,
  "skipAutoPermissionPrompt": true
}
